    "BEGIN\n",
    "\n",
    "    INPUT name1\n",
    "    INPUT age1\n",
    "\n",
    "    INPUT name2\n",
    "    INPUT age2\n",
    "\n",
    "    temp = age1\n",
    "    age1 = age2\n",
    "    age2 = temp\n",
    "\n",
    "    OUTPUT \"After swapping:\"\n",
    "    OUTPUT name1 + \" is now \" + age1\n",
    "    OUTPUT name2 + \" is now \" + age2\n",
    "\n",
    "END"
   ]
