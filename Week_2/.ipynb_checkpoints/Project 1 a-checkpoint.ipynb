   "metadata": {},
   "source": [
    "INPUT item(s)\n",
    "INPUT quantity\n",
    "COMPUTE price = item * quantity\n",
    "PRINT price\n",
    "INPUT money\n",
    "IF money < price\n",
    "PRINT Transaction ends, return items\n",
    "ElSE\n",
    "PRINT transaction complete\n"
   ]
  },
